<% content_for :title, "Friends" %>

<h1>Friends</h1>

<table class = "table table-striped table-bordered table-hover">
  <thead class = "table-dark">
    <tr>
      <th>First Name</th>
      <th>Last Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Twitter</th>
      <th>User Id</th>
      <th colspan ="3"></th>
    </tr>
  </thead>

  <tbody>
    <div id="friends">
      <% @friends.each do |friend| %>
        <%if friend.user == current_user %>
          <tr> 
            <%= render friend %>

            <td>
              <%= link_to "Show", friend %>
            </td>

            <td>
              <%= link_to "Edit", edit_friend_path(friend)%>
            </td>

            <td>
              <%= link_to "Delete", friend, method: :delete%>
            </td>
          </tr>
        <% end %>
      <% end %>
    </div>
  </tbody>
</table>


<%= link_to "New friend", new_friend_path, class: "btn btn-secondary" %>

